<% content_for :title, "注文詳細" %>
<% back_path = local_assigns.fetch(:back_path, orders_path) %>
<% admin_view = local_assigns.fetch(:admin_view, @admin_view || false) %>

<section class="rounded-[2rem] border border-stone-200 bg-white p-6 shadow-sm">
  <div class="mb-6 flex items-start justify-between gap-4">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.25em] text-amber-700">Order</p>
      <h1 class="mt-3 text-3xl font-semibold text-stone-900"><%= @order.order_cycle.label %> の注文</h1>
      <p class="mt-2 text-sm text-stone-500"><%= @order.organization.name %> / <%= @order.orderer_name %></p>
    </div>
    <%= link_to "一覧へ戻る", back_path, class: "rounded-xl border border-stone-300 px-4 py-2 text-sm font-medium text-stone-700 hover:bg-stone-100" %>
  </div>

  <div class="grid gap-4 md:grid-cols-4">
    <% if admin_view %>
      <div class="rounded-2xl bg-stone-50 p-4">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-stone-500">ログインユーザー</p>
        <p class="mt-2 font-medium text-stone-900"><%= @order.user.name %></p>
      </div>
    <% end %>
    <div class="rounded-2xl bg-stone-50 p-4">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-stone-500">持ち帰り者</p>
      <p class="mt-2 font-medium text-stone-900"><%= @order.pickup_name %></p>
    </div>
    <div class="rounded-2xl bg-stone-50 p-4">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-stone-500">状態</p>
      <p class="mt-2 font-medium text-stone-900"><%= @order.status %></p>
    </div>
    <div class="rounded-2xl bg-stone-50 p-4">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-stone-500">注文日</p>
      <p class="mt-2 font-medium text-stone-900"><%= l(@order.order_cycle.order_date) %></p>
    </div>
    <div class="rounded-2xl bg-stone-50 p-4">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-stone-500">提出日時</p>
      <p class="mt-2 font-medium text-stone-900"><%= l(@order.submitted_at, format: :long) if @order.submitted_at %></p>
    </div>
  </div>

  <div class="mt-6 overflow-hidden rounded-3xl border border-stone-200">
    <table class="min-w-full divide-y divide-stone-200 text-sm">
      <thead class="bg-stone-50 text-left text-xs font-semibold uppercase tracking-[0.2em] text-stone-500">
        <tr>
          <th class="px-4 py-3">コード</th>
          <th class="px-4 py-3">道具名</th>
          <th class="px-4 py-3">種別</th>
          <th class="px-4 py-3">数量</th>
          <th class="px-4 py-3">単位</th>
          <th class="px-4 py-3">備考</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-stone-200">
        <% @order.order_items.each do |item| %>
          <tr>
            <td class="px-4 py-3"><%= item.item_code %></td>
            <td class="px-4 py-3"><%= item.item_name %></td>
            <td class="px-4 py-3"><%= item.variant_name %></td>
            <td class="px-4 py-3"><%= item.quantity %></td>
            <td class="px-4 py-3"><%= item.unit %></td>
            <td class="px-4 py-3"><%= item.notes %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
