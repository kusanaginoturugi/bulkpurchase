<%= form_with model: [ :admin, organization ], class: "mt-6 space-y-4" do |form| %>
  <% if organization.errors.any? %>
    <div class="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-800">
      <p class="font-semibold">入力内容を確認してください。</p>
      <ul class="mt-2 list-disc pl-5">
        <% organization.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :code, "伝道会番号", class: "text-sm font-medium text-stone-700" %>
    <%= form.text_field :code, class: "mt-2 block w-full rounded-xl border border-stone-300 bg-stone-50 px-4 py-3" %>
  </div>
  <div>
    <%= form.label :name, "伝道会名", class: "text-sm font-medium text-stone-700" %>
    <%= form.text_field :name, class: "mt-2 block w-full rounded-xl border border-stone-300 bg-stone-50 px-4 py-3" %>
  </div>
  <label class="flex items-center gap-3 text-sm text-stone-700">
    <%= form.check_box :active %>
    有効
  </label>
  <div class="flex gap-3">
    <%= form.submit(organization.persisted? ? "伝道会を更新" : "伝道会を登録", class: "rounded-xl bg-stone-900 px-5 py-3 text-sm font-medium text-white") %>
    <%= link_to "一覧へ戻る", admin_organizations_path, class: "rounded-xl border border-stone-300 px-5 py-3 text-sm font-medium text-stone-700" %>
  </div>
<% end %>
