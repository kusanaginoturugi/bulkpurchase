<%= render "admin/shared/header", title: "ユーザー編集", description: @user.name %>
<section class="rounded-[2rem] border border-stone-200 bg-white p-6 shadow-sm">
  <%= render "form", user: @user, organizations: @organizations %>
  <% unless @user == current_user %>
    <div class="mt-6 border-t border-stone-200 pt-6">
      <%= button_to "このユーザーを削除", admin_user_path(@user), method: :delete, class: "rounded-xl border border-rose-200 px-5 py-3 text-sm font-medium text-rose-700 hover:bg-rose-50", form: { data: { turbo_confirm: "#{@user.name}を削除しますか？" } } %>
    </div>
  <% end %>
</section>
