<div class="mx-auto max-w-md rounded-[2rem] border border-stone-200 bg-white p-8 shadow-sm">
  <div class="mb-8">
    <p class="text-xs font-semibold uppercase tracking-[0.25em] text-amber-700">Login</p>
    <h1 class="mt-3 text-3xl font-semibold text-stone-900">注文システムにログイン</h1>
    <p class="mt-2 text-sm text-stone-500">登録済みのメールアドレスとパスワードを入力してください。</p>
  </div>

  <%= form_with url: session_url, class: "space-y-5" do |form| %>
    <div>
      <%= form.label :email_address, "メールアドレス", class: "text-sm font-medium text-stone-700" %>
      <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", value: params[:email_address], class: "mt-2 block w-full rounded-xl border border-stone-300 bg-stone-50 px-4 py-3 focus:border-amber-500 focus:bg-white focus:outline-none" %>
    </div>

    <div>
      <%= form.label :password, "パスワード", class: "text-sm font-medium text-stone-700" %>
      <%= form.password_field :password, required: true, autocomplete: "current-password", maxlength: 72, class: "mt-2 block w-full rounded-xl border border-stone-300 bg-stone-50 px-4 py-3 focus:border-amber-500 focus:bg-white focus:outline-none" %>
    </div>

    <div class="flex items-center justify-between gap-4 pt-2">
      <%= form.submit "ログイン", class: "inline-flex rounded-xl bg-stone-900 px-5 py-3 text-sm font-medium text-white hover:bg-stone-700" %>
      <%= link_to "パスワードを忘れた場合", new_password_path, class: "text-sm text-stone-500 underline-offset-4 hover:text-stone-900 hover:underline" %>
    </div>
  <% end %>
</div>
