<%= render "admin/shared/header", title: "ユーザー管理", description: "ログインユーザーと所属伝道会を管理します。" %>

<div class="grid gap-6 lg:grid-cols-[1.2fr,0.8fr]">
  <section class="rounded-[2rem] border border-stone-200 bg-white p-6 shadow-sm">
    <table class="min-w-full divide-y divide-stone-200 text-sm">
      <thead class="text-left text-xs font-semibold uppercase tracking-[0.2em] text-stone-500">
        <tr>
          <th class="py-3">氏名</th>
          <th class="py-3">メール</th>
          <th class="py-3">伝道会</th>
          <th class="py-3">権限</th>
          <th class="py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-stone-200">
        <% @users.each do |user| %>
          <tr>
            <td class="py-3"><%= user.name %></td>
            <td class="py-3"><%= user.email_address %></td>
            <td class="py-3"><%= user.organization.name %></td>
            <td class="py-3"><%= user.role %></td>
            <td class="py-3 text-right"><%= link_to "編集", edit_admin_user_path(user), class: "font-medium text-stone-900" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </section>

  <section class="rounded-[2rem] border border-stone-200 bg-white p-6 shadow-sm">
    <h2 class="text-xl font-semibold text-stone-900">新規登録</h2>
    <%= render "form", user: @user, organizations: @organizations %>
  </section>
</div>
