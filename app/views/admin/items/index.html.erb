<%= render "admin/shared/header", title: "道具マスタ管理", description: "単位・特殊道具設定を更新します。" %>

<div class="grid gap-6 lg:grid-cols-[1.45fr,0.55fr]">
  <section class="space-y-6">
    <div class="grid gap-6 lg:grid-cols-2">
      <% @items_by_prefix.each do |prefix, items| %>
        <div class="rounded-[2rem] border border-stone-200 bg-white p-6 shadow-sm">
          <h2 class="mb-4 text-xl font-semibold text-stone-900"><%= prefix %>で始まる道具</h2>
          <table class="min-w-full divide-y divide-stone-200 text-sm">
            <thead class="text-left text-xs font-semibold uppercase tracking-[0.2em] text-stone-500">
              <tr>
                <th class="py-3">コード</th>
                <th class="py-3">名称</th>
                <th class="py-3">単位</th>
                <th class="py-3"></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-stone-200">
              <% items.each do |item| %>
                <tr>
                  <td class="py-3 pr-2 whitespace-nowrap"><%= item.code %></td>
                  <td class="py-3 pr-2"><%= item.name %></td>
                  <td class="py-3 pr-2 whitespace-nowrap"><%= item.unit %></td>
                  <td class="py-3 text-right"><%= link_to "編集", edit_admin_item_path(item), class: "font-medium text-stone-900" %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
    </div>
  </section>

  <section class="rounded-[2rem] border border-stone-200 bg-white p-6 shadow-sm">
    <h2 class="text-xl font-semibold text-stone-900">新規登録</h2>
    <%= render "form", item: @item %>
  </section>
</div>
