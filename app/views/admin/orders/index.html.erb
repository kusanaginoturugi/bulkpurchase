<%= render "admin/shared/header", title: "注文一覧", description: "各伝道会の提出内容を確認します。" %>

<section class="rounded-[2rem] border border-stone-200 bg-white p-6 shadow-sm">
  <table class="min-w-full divide-y divide-stone-200 text-sm">
    <thead class="text-left text-xs font-semibold uppercase tracking-[0.2em] text-stone-500">
      <tr>
        <th class="py-3">対象月</th>
        <th class="py-3">伝道会</th>
        <th class="py-3">注文者</th>
        <th class="py-3">状態</th>
        <th class="py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-stone-200">
      <% @orders.each do |order| %>
        <tr>
          <td class="py-3"><%= order.order_cycle.label %></td>
          <td class="py-3"><%= order.organization.name %></td>
          <td class="py-3"><%= order.orderer_name %></td>
          <td class="py-3"><%= order.status %></td>
          <td class="py-3 text-right"><%= link_to "詳細", admin_order_path(order), class: "font-medium text-stone-900" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</section>
