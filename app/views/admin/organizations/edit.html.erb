<%= render "admin/shared/header", title: "伝道会編集", description: @organization.display_name %>
<section class="rounded-[2rem] border border-stone-200 bg-white p-6 shadow-sm">
  <%= render "form", organization: @organization %>
  <div class="mt-6 border-t border-stone-200 pt-6">
    <%= button_to "この伝道会を削除", admin_organization_path(@organization), method: :delete, class: "rounded-xl border border-rose-200 px-5 py-3 text-sm font-medium text-rose-700 hover:bg-rose-50", form: { data: { turbo_confirm: "#{@organization.display_name}を削除しますか？" } } %>
  </div>
</section>
