<% content_for :title, "注文履歴" %>

<section class="rounded-[2rem] border border-stone-200 bg-white p-6 shadow-sm">
  <div class="mb-6 flex items-end justify-between gap-4">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.25em] text-amber-700">History</p>
      <h1 class="mt-3 text-3xl font-semibold text-stone-900">注文履歴</h1>
    </div>
    <%= link_to "現在の注文へ", current_order_path, class: "rounded-xl border border-stone-300 px-4 py-2 text-sm font-medium text-stone-700 hover:bg-stone-100" %>
  </div>

  <div class="overflow-hidden rounded-3xl border border-stone-200">
    <table class="min-w-full divide-y divide-stone-200 text-sm">
      <thead class="bg-stone-50 text-left text-xs font-semibold uppercase tracking-[0.2em] text-stone-500">
        <tr>
          <th class="px-4 py-3">対象月</th>
          <th class="px-4 py-3">伝道会</th>
          <th class="px-4 py-3">状態</th>
          <th class="px-4 py-3">提出日時</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-stone-200">
        <% @orders.each do |order| %>
          <tr>
            <td class="px-4 py-3"><%= order.order_cycle.label %></td>
            <td class="px-4 py-3"><%= order.organization.name %></td>
            <td class="px-4 py-3"><%= order.status %></td>
            <td class="px-4 py-3"><%= l(order.submitted_at, format: :long) if order.submitted_at %></td>
            <td class="px-4 py-3 text-right"><%= link_to "詳細", order_path(order), class: "font-medium text-stone-900 underline-offset-4 hover:underline" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
