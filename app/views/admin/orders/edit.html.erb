<%= render "admin/shared/header", title: "注文編集", description: "#{@order.order_cycle.label} / #{@order.user.name}" %>

<section class="rounded-[2rem] border border-stone-200 bg-white p-6 shadow-sm">
  <% if @order.errors.any? %>
    <div class="mb-6 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-800">
      <p class="font-semibold">入力内容を確認してください。</p>
      <ul class="mt-2 list-disc pl-5">
        <% @order.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= render "current_orders/form",
    order: @order,
    form_url: admin_order_path(@order),
    organization_selectable: true,
    organizations: @organizations,
    readonly: false,
    detail_path: admin_order_path(@order),
    back_path: admin_orders_path %>
</section>
