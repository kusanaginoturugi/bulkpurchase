<%= render "admin/shared/header", title: "伝道会管理", description: "注文対象の伝道会を管理します。" %>

<div class="grid gap-6 lg:grid-cols-[1.1fr,0.9fr]">
  <section class="rounded-[2rem] border border-stone-200 bg-white p-6 shadow-sm">
    <table class="min-w-full divide-y divide-stone-200 text-sm">
      <thead class="text-left text-xs font-semibold uppercase tracking-[0.2em] text-stone-500">
        <tr>
          <th class="w-28 py-3 pr-2">伝道会番号</th>
          <th class="py-3 pl-0">伝道会名</th>
          <th class="py-3">有効</th>
          <th class="py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-stone-200">
        <% @organizations.each do |organization| %>
          <tr>
            <td class="w-28 py-3 pr-2"><%= organization.code %></td>
            <td class="py-3 pl-0"><%= organization.name %></td>
            <td class="py-3"><%= organization.active? ? "有効" : "無効" %></td>
            <td class="py-3">
              <div class="flex justify-end gap-3">
                <%= link_to "編集", edit_admin_organization_path(organization), class: "font-medium text-stone-900" %>
                <%= button_to "削除", admin_organization_path(organization), method: :delete, class: "font-medium text-rose-700", form: { data: { turbo_confirm: "#{organization.display_name}を削除しますか？" } } %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </section>

  <section class="rounded-[2rem] border border-stone-200 bg-white p-6 shadow-sm">
    <h2 class="text-xl font-semibold text-stone-900">新規登録</h2>
    <%= render "form", organization: @organization %>
  </section>
</div>
