<%= render "admin/shared/header", title: "注文サイクル管理", description: "月例番号、締切、注文日、必着日を設定します。" %>

<div class="grid gap-6 lg:grid-cols-[1.15fr,0.85fr]">
  <section class="rounded-[2rem] border border-stone-200 bg-white p-6 shadow-sm">
    <table class="min-w-full divide-y divide-stone-200 text-sm">
      <thead class="text-left text-xs font-semibold uppercase tracking-[0.2em] text-stone-500">
        <tr>
          <th class="py-3">対象月</th>
          <th class="py-3">月例</th>
          <th class="py-3">締切</th>
          <th class="py-3">状態</th>
          <th class="py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-stone-200">
        <% @order_cycles.each do |order_cycle| %>
          <tr>
            <td class="py-3"><%= order_cycle.label %></td>
            <td class="py-3"><%= order_cycle.cycle_number %></td>
            <td class="py-3"><%= l(order_cycle.deadline_at, format: :long) %></td>
            <td class="py-3"><%= order_cycle.status %></td>
            <td class="py-3 text-right">
              <%= link_to "詳細", admin_order_cycle_path(order_cycle), class: "mr-3 font-medium text-stone-900" %>
              <%= link_to "編集", edit_admin_order_cycle_path(order_cycle), class: "font-medium text-stone-900" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </section>

  <section class="rounded-[2rem] border border-stone-200 bg-white p-6 shadow-sm">
    <h2 class="text-xl font-semibold text-stone-900">新規登録</h2>
    <%= render "form", order_cycle: @order_cycle %>
  </section>
</div>
