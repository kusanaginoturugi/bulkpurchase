<% content_for :title, "現在の注文" %>

<% if @order_cycle.nil? %>
  <section class="rounded-[2rem] border border-stone-200 bg-white p-8 shadow-sm">
    <h1 class="text-2xl font-semibold text-stone-900">現在受付中の注文はありません</h1>
    <p class="mt-3 text-sm text-stone-600">管理者が次の注文サイクルを登録すると、ここから注文入力できます。</p>
  </section>
<% else %>
  <section class="mb-6 grid gap-4 lg:grid-cols-4">
    <div class="rounded-3xl border border-amber-200 bg-amber-50 p-6 text-stone-900 lg:col-span-2">
      <p class="text-xs font-semibold uppercase tracking-[0.25em] text-amber-700">現在の注文月</p>
      <h1 class="mt-3 text-3xl font-semibold"><%= @order_cycle.label %></h1>
      <p class="mt-2 text-sm text-stone-600">注文日 <%= l(@order_cycle.order_date) %> / 必着日 <%= l(@order_cycle.arrival_date) %></p>
    </div>
    <div class="rounded-3xl border border-stone-200 bg-white p-6">
      <p class="text-xs font-semibold uppercase tracking-[0.25em] text-stone-400">締切</p>
      <p class="mt-3 text-xl font-semibold text-stone-900"><%= l(@order_cycle.deadline_at, format: :long) %></p>
    </div>
    <div class="rounded-3xl border border-stone-200 bg-white p-6">
      <p class="text-xs font-semibold uppercase tracking-[0.25em] text-stone-400">状態</p>
      <p class="mt-3 text-xl font-semibold text-stone-900"><%= @order.editable_by_user? ? "修正可能" : "送信済み" %></p>
      <% if @order.submitted? %>
        <p class="mt-2 text-sm text-stone-500">提出日時: <%= l(@order.submitted_at, format: :long) if @order.submitted_at %></p>
      <% end %>
    </div>
  </section>

  <section class="rounded-[2rem] border border-stone-200 bg-white p-6 shadow-sm">
    <% if @order.errors.any? %>
      <div class="mb-6 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-800">
        <p class="font-semibold">入力内容を確認してください。</p>
        <ul class="mt-2 list-disc pl-5">
          <% @order.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= render "form", order: @order, form_url: current_order_path, organization_selectable: false, organizations: @organizations, back_path: nil %>
  </section>
<% end %>
