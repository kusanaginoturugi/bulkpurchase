<%= form_with model: [ :admin, order_cycle ], class: "mt-6 space-y-4" do |form| %>
  <div class="grid gap-4 md:grid-cols-2">
    <div>
      <%= form.label :year, "年", class: "text-sm font-medium text-stone-700" %>
      <%= form.number_field :year, class: "mt-2 block w-full rounded-xl border border-stone-300 bg-stone-50 px-4 py-3" %>
    </div>
    <div>
      <%= form.label :month, "月", class: "text-sm font-medium text-stone-700" %>
      <%= form.number_field :month, min: 1, max: 12, class: "mt-2 block w-full rounded-xl border border-stone-300 bg-stone-50 px-4 py-3" %>
    </div>
  </div>
  <div>
    <%= form.label :cycle_number, "月例番号", class: "text-sm font-medium text-stone-700" %>
    <%= form.number_field :cycle_number, class: "mt-2 block w-full rounded-xl border border-stone-300 bg-stone-50 px-4 py-3" %>
  </div>
  <div>
    <%= form.label :deadline_at, "締切日時", class: "text-sm font-medium text-stone-700" %>
    <%= form.datetime_local_field :deadline_at, value: order_cycle.deadline_at&.strftime("%Y-%m-%dT%H:%M"), class: "mt-2 block w-full rounded-xl border border-stone-300 bg-stone-50 px-4 py-3" %>
  </div>
  <div class="grid gap-4 md:grid-cols-2">
    <div>
      <%= form.label :order_date, "注文日", class: "text-sm font-medium text-stone-700" %>
      <%= form.date_field :order_date, class: "mt-2 block w-full rounded-xl border border-stone-300 bg-stone-50 px-4 py-3" %>
    </div>
    <div>
      <%= form.label :arrival_date, "必着日", class: "text-sm font-medium text-stone-700" %>
      <%= form.date_field :arrival_date, class: "mt-2 block w-full rounded-xl border border-stone-300 bg-stone-50 px-4 py-3" %>
    </div>
  </div>
  <div>
    <%= form.label :status, "状態", class: "text-sm font-medium text-stone-700" %>
    <%= form.select :status, OrderCycle.status_options, {}, class: "mt-2 block w-full rounded-xl border border-stone-300 bg-stone-50 px-4 py-3" %>
  </div>
  <div class="flex gap-3">
    <%= form.submit(order_cycle.persisted? ? "注文サイクルを更新" : "注文サイクルを登録", class: "rounded-xl bg-stone-900 px-5 py-3 text-sm font-medium text-white") %>
    <%= link_to "一覧へ戻る", admin_order_cycles_path, class: "rounded-xl border border-stone-300 px-5 py-3 text-sm font-medium text-stone-700" %>
  </div>
<% end %>
