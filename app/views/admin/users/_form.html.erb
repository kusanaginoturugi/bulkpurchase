<%= form_with model: [ :admin, user ], class: "mt-6 space-y-4" do |form| %>
  <% if user.errors.any? %>
    <div class="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-800">
      <p class="font-semibold">入力内容を確認してください。</p>
      <ul class="mt-2 list-disc pl-5">
        <% user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, "氏名", class: "text-sm font-medium text-stone-700" %>
    <%= form.text_field :name, class: "mt-2 block w-full rounded-xl border border-stone-300 bg-stone-50 px-4 py-3" %>
  </div>
  <div>
    <%= form.label :email_address, "メールアドレス", class: "text-sm font-medium text-stone-700" %>
    <%= form.email_field :email_address, class: "mt-2 block w-full rounded-xl border border-stone-300 bg-stone-50 px-4 py-3" %>
  </div>
  <div class="grid gap-4 md:grid-cols-2">
    <div>
      <%= form.label :password, user.persisted? ? "パスワード（変更する場合のみ）" : "パスワード", class: "text-sm font-medium text-stone-700" %>
      <%= form.password_field :password, class: "mt-2 block w-full rounded-xl border border-stone-300 bg-stone-50 px-4 py-3" %>
    </div>
    <div>
      <%= form.label :password_confirmation, "確認用", class: "text-sm font-medium text-stone-700" %>
      <%= form.password_field :password_confirmation, class: "mt-2 block w-full rounded-xl border border-stone-300 bg-stone-50 px-4 py-3" %>
    </div>
  </div>
  <div class="grid gap-4 md:grid-cols-2">
    <div>
      <%= form.label :organization_id, "伝道会", class: "text-sm font-medium text-stone-700" %>
      <%= form.collection_select :organization_id, organizations, :id, :display_name, {}, class: "mt-2 block w-full rounded-xl border border-stone-300 bg-stone-50 px-4 py-3" %>
    </div>
    <div>
      <%= form.label :role, "権限", class: "text-sm font-medium text-stone-700" %>
      <%= form.select :role, User.role_options, {}, class: "mt-2 block w-full rounded-xl border border-stone-300 bg-stone-50 px-4 py-3" %>
    </div>
  </div>
  <label class="flex items-center gap-3 text-sm text-stone-700">
    <%= form.check_box :active %>
    有効
  </label>
  <div class="flex gap-3">
    <%= form.submit(user.persisted? ? "ユーザーを更新" : "ユーザーを登録", class: "rounded-xl bg-stone-900 px-5 py-3 text-sm font-medium text-white") %>
    <%= link_to "一覧へ戻る", admin_users_path, class: "rounded-xl border border-stone-300 px-5 py-3 text-sm font-medium text-stone-700" %>
  </div>
<% end %>
