<%= render "admin/shared/header", title: "ユーザー管理", description: "ログインユーザーと所属伝道会を管理します。" %>

<div class="grid gap-6 lg:grid-cols-[1.2fr,0.8fr]">
  <section class="rounded-[2rem] border border-stone-200 bg-white p-6 shadow-sm">
    <div class="mb-4 flex items-center justify-between gap-4">
      <h2 class="text-xl font-semibold text-stone-900">登録済みユーザー</h2>
      <%= link_to "自分の情報を更新", edit_admin_user_path(current_user), class: "rounded-xl border border-stone-300 px-4 py-2 text-sm font-medium text-stone-700 hover:bg-stone-100" %>
    </div>
    <table class="min-w-full divide-y divide-stone-200 text-sm">
      <thead class="text-left text-xs font-semibold uppercase tracking-[0.2em] text-stone-500">
        <tr>
          <th class="py-3">氏名</th>
          <th class="py-3">メール</th>
          <th class="py-3">伝道会</th>
          <th class="py-3">権限</th>
          <th class="py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-stone-200">
        <% @users.each do |user| %>
          <tr>
            <td class="py-3"><%= user.name %></td>
            <td class="py-3"><%= user.email_address %></td>
            <td class="py-3"><%= user.organization.display_name %></td>
            <td class="py-3"><%= user.role_label %></td>
            <td class="py-3">
              <div class="flex justify-end gap-3">
                <%= link_to "編集", edit_admin_user_path(user), class: "font-medium text-stone-900" %>
                <% unless user == current_user %>
                  <%= button_to "削除", admin_user_path(user), method: :delete, class: "font-medium text-rose-700", form: { data: { turbo_confirm: "#{user.name}を削除しますか？" } } %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </section>

  <section class="rounded-[2rem] border border-stone-200 bg-white p-6 shadow-sm">
    <h2 class="text-xl font-semibold text-stone-900">新規登録</h2>
    <%= render "form", user: @user, organizations: @organizations %>
  </section>
</div>
