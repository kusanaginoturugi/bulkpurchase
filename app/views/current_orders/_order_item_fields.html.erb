<% order_item = f.object %>
<% query_value = order_item.item_name.presence || order_item.item_code %>

<div class="grid gap-3 px-4 py-4" style="grid-template-columns: 2fr 1.25fr 0.45fr 0.45fr 13rem;" data-controller="item-autocomplete">
  <div class="relative">
    <%= f.hidden_field :id if order_item.persisted? %>
    <%= f.hidden_field :item_id, data: { item_autocomplete_target: "itemId" } %>
    <%= f.hidden_field :item_code, data: { item_autocomplete_target: "itemCode" } %>
    <%= f.text_field :item_name, placeholder: "コードまたは道具名", readonly:, class: "block w-full rounded-xl border border-stone-300 bg-white px-4 py-3 text-lg focus:border-amber-500 focus:outline-none disabled:bg-stone-100", data: { action: "input->item-autocomplete#syncQuery input->item-autocomplete#search", item_autocomplete_target: "query itemName", original_value: query_value } %>
    <div data-item-autocomplete-target="menu" class="absolute z-10 mt-1 hidden min-w-full overflow-x-auto rounded-xl border border-stone-200 bg-white shadow-lg"></div>
  </div>

  <div>
    <%= f.hidden_field :item_variant_id %>
    <%= f.text_field :variant_name, readonly:, class: "block w-full rounded-xl border border-stone-300 bg-white px-4 py-3 text-lg focus:border-amber-500 focus:outline-none disabled:bg-stone-100", data: { item_autocomplete_target: "variantName" } %>
  </div>

  <div>
    <%= f.text_field :quantity, inputmode: "numeric", pattern: "[0-9]*", readonly:, class: "block w-full rounded-xl border border-stone-300 bg-white px-4 py-3 text-lg focus:border-amber-500 focus:outline-none disabled:bg-stone-100" %>
  </div>

  <div>
    <%= f.text_field :unit, readonly:, class: "block w-full rounded-xl border border-stone-300 bg-white px-4 py-3 text-lg focus:border-amber-500 focus:outline-none disabled:bg-stone-100", data: { item_autocomplete_target: "unit" } %>
  </div>

  <%= f.hidden_field :sort_order %>
  <%= f.hidden_field :_destroy %>

  <div class="flex items-start justify-end gap-2">
    <% unless readonly %>
      <button type="button" data-action="order-items#add" class="rounded-xl border border-dashed border-stone-400 px-3 py-3 text-lg text-stone-600 hover:border-stone-700 hover:text-stone-900">行を追加</button>
      <button type="button" data-action="order-items#remove" class="rounded-xl border border-rose-200 px-4 py-3 text-lg text-rose-700 hover:bg-rose-50">削除</button>
    <% end %>
  </div>
</div>
