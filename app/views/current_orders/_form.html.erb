<% readonly = local_assigns.fetch(:readonly, !order.editable_by_user?) %>
<% form_method = order.persisted? ? :patch : :post %>
<% organization_selectable = local_assigns.fetch(:organization_selectable, false) %>
<% organizations = local_assigns.fetch(:organizations, []) %>
<% form_url = local_assigns.fetch(:form_url, current_order_path) %>
<% back_path = local_assigns[:back_path] %>

<%= form_with model: order, url: form_url, method: form_method, class: "space-y-8", data: { controller: "order-items" } do |form| %>
  <div class="grid gap-6 md:grid-cols-3">
    <div>
      <%= form.label :orderer_name, "注文者名", class: "text-sm font-medium text-stone-700" %>
      <%= form.text_field :orderer_name, readonly:, class: "mt-2 block w-full rounded-xl border border-stone-300 bg-stone-50 px-4 py-3 focus:border-amber-500 focus:bg-white focus:outline-none disabled:cursor-not-allowed disabled:bg-stone-100" %>
    </div>
    <div>
      <%= form.label :pickup_name, "持ち帰り者名", class: "text-sm font-medium text-stone-700" %>
      <%= form.text_field :pickup_name, readonly:, class: "mt-2 block w-full rounded-xl border border-stone-300 bg-stone-50 px-4 py-3 focus:border-amber-500 focus:bg-white focus:outline-none disabled:cursor-not-allowed disabled:bg-stone-100" %>
    </div>
    <div>
      <label class="text-sm font-medium text-stone-700">伝道会</label>
      <% if organization_selectable %>
        <%= form.collection_select :organization_id, organizations, :id, :name, {}, disabled: readonly, class: "mt-2 block w-full rounded-xl border border-stone-300 bg-stone-50 px-4 py-3 focus:border-amber-500 focus:bg-white focus:outline-none disabled:cursor-not-allowed disabled:bg-stone-100" %>
      <% else %>
        <div class="mt-2 rounded-xl border border-stone-200 bg-stone-100 px-4 py-3 text-stone-700"><%= order.organization&.name || current_user.organization.name %></div>
      <% end %>
    </div>
  </div>

  <div class="overflow-x-auto rounded-3xl border border-stone-200">
    <div class="min-w-[980px]">
      <div class="grid gap-3 border-b border-stone-200 bg-stone-50 px-4 py-3 text-xs font-semibold uppercase tracking-[0.2em] text-stone-500" style="grid-template-columns: 1.2fr 0.9fr 1.1fr 0.7fr 0.6fr 1fr auto;">
        <div>検索</div>
        <div>道具コード</div>
        <div>道具名</div>
        <div>種別</div>
        <div>数量</div>
        <div>単位 / 備考</div>
        <div></div>
      </div>

      <div data-order-items-target="container" class="divide-y divide-stone-200">
        <%= form.fields_for :order_items do |item_fields| %>
          <%= render "order_item_fields", f: item_fields, readonly: readonly %>
        <% end %>
      </div>
    </div>
  </div>

  <% unless readonly %>
    <button type="button" data-action="order-items#add" class="inline-flex rounded-xl border border-dashed border-stone-400 px-4 py-2 text-sm font-medium text-stone-600 hover:border-stone-700 hover:text-stone-900">
      行を追加
    </button>
  <% end %>

  <template data-order-items-target="template">
    <%= form.fields_for :order_items, OrderItem.new(sort_order: order.order_items.size), child_index: "NEW_RECORD" do |item_fields| %>
      <%= render "order_item_fields", f: item_fields, readonly: readonly %>
    <% end %>
  </template>

  <div class="flex flex-wrap gap-3 border-t border-stone-200 pt-6">
    <% unless readonly %>
      <%= button_tag "保存", name: "commit_action", value: "save", class: "inline-flex rounded-xl border border-stone-300 px-5 py-3 text-sm font-medium text-stone-700 hover:bg-stone-100" %>
      <%= button_tag "提出する", name: "commit_action", value: "submit", class: "inline-flex rounded-xl bg-stone-900 px-5 py-3 text-sm font-medium text-white hover:bg-stone-700" %>
    <% end %>
    <% if order.persisted? %>
      <%= link_to "注文詳細を見る", local_assigns.fetch(:detail_path, order_path(order)), class: "inline-flex rounded-xl border border-stone-300 px-5 py-3 text-sm font-medium text-stone-700 hover:bg-stone-100" %>
    <% end %>
    <% if back_path.present? %>
      <%= link_to "一覧へ戻る", back_path, class: "inline-flex rounded-xl border border-stone-300 px-5 py-3 text-sm font-medium text-stone-700 hover:bg-stone-100" %>
    <% end %>
  </div>
<% end %>
